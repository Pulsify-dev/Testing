{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@locators": ["./fixtures/locators.ts"]
    },
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["tests/**/*.ts", "fixtures/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
