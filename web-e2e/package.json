{
  "name": "web-e2e",
  "version": "1.0.0",
  "description": "Pulsify E2E test suite — Playwright + ESLint selector-safety enforcement",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test --grep @auth",
    "test:playback": "playwright test --grep @playback",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "lint": "eslint --rulesdir eslint-rules \"tests/**/*.ts\" \"fixtures/**/*.ts\"",
    "lint:fix": "eslint --rulesdir eslint-rules \"tests/**/*.ts\" \"fixtures/**/*.ts\" --fix",
    "lint:rule-tests": "node eslint-rules/no-hardcoded-selectors.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "~5.5.4"
  }
}
