{
  "name": "testing",
  "version": "1.0.0",
  "description": "End-to-end, mobile integration, and performance stress tests for the **Pulsify** music streaming platform. Three independent testing pillars live side-by-side in this repo:",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "gui": "powershell -ExecutionPolicy Bypass -File ./scripts/playwright-ui.ps1",
    "gui:m1": "powershell -ExecutionPolicy Bypass -File ./scripts/playwright-ui.ps1 -Scope module1",
    "test:e2e:m1:terminal": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m1-terminal.ps1",
    "test:e2e:m1:ui:script": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m1-ui.ps1",
    "test:e2e:m2:terminal": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m2-terminal.ps1",
    "test:e2e:m2:ui:script": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m2-ui.ps1",
    "test:e2e:m3:terminal": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m3-terminal.ps1",
    "test:e2e:m3:ui:script": "powershell -ExecutionPolicy Bypass -File ./scripts/run-m3-ui.ps1",
    "test:e2e:m1:v04:live": "powershell -ExecutionPolicy Bypass -File ./scripts/run-live-registration-tc04.ps1",
    "test:e2e:sc:m4": "playwright test -c scripts/playwright.config.js scripts/e2e/benchmark/soundcloud/module-04-tracks --project=chromium",
    "test:e2e:sc:m5": "playwright test -c scripts/playwright.config.js scripts/e2e/benchmark/soundcloud/module-05-playback --project=chromium",
    "test:e2e:sc:m6": "playwright test -c scripts/playwright.config.js scripts/e2e/benchmark/soundcloud/module-06-engagement --project=chromium",
    "test:e2e:sc:m4-m6": "playwright test -c scripts/playwright.config.js scripts/e2e/benchmark/soundcloud --project=chromium",
    "test:e2e:sc:m4-m6:headed": "powershell -ExecutionPolicy Bypass -File ./scripts/run-soundcloud-m4-m6.ps1",
    "test:e2e": "playwright test -c scripts/playwright.config.js",
    "test:e2e:headed": "playwright test -c scripts/playwright.config.js --headed",
    "test:e2e:ui": "playwright test -c scripts/playwright.config.js --ui",
    "test:e2e:auth": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-01-auth",
    "test:e2e:auth:ui": "playwright test -c scripts/playwright.config.js --ui scripts/e2e/modules/module-01-auth --project=chromium",
    "test:e2e:profile": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-02-profile",
    "test:e2e:m1": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-01-auth",
    "test:e2e:m2": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-02-profile",
    "test:e2e:m3": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-03-social",
    "test:e2e:m4": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-04-tracks",
    "test:e2e:m5": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-05-playback",
    "test:e2e:m6": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-06-engagement",
    "test:e2e:m1-m3": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-01-auth scripts/e2e/modules/module-02-profile scripts/e2e/modules/module-03-social",
    "test:e2e:m1-m3:chromium": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-01-auth scripts/e2e/modules/module-02-profile scripts/e2e/modules/module-03-social --project=chromium",
    "test:e2e:m4-m6": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-04-tracks scripts/e2e/modules/module-05-playback scripts/e2e/modules/module-06-engagement",
    "test:e2e:m4-m6:chromium": "playwright test -c scripts/playwright.config.js scripts/e2e/modules/module-04-tracks scripts/e2e/modules/module-05-playback scripts/e2e/modules/module-06-engagement --project=chromium",
    "test:e2e:m1-m6": "playwright test -c scripts/playwright.config.js scripts/e2e/modules",
    "test:e2e:report": "playwright show-report",
    "test:e2e:list": "playwright test -c scripts/playwright.config.js --list",
    "install:browsers": "playwright install --with-deps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pulsify-dev/Testing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Pulsify-dev/Testing/issues"
  },
  "homepage": "https://github.com/Pulsify-dev/Testing#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  }
}
